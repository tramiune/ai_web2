# Aidancing Pure HTTP
AIDANCING_COOKIE=JSESSIONID=your_session_here

# XiaoYang API (đơn mới khi Admin chọn XiaoYang)
XIAOYANG_API_KEY=xy_your_key_here
XIAOYANG_DIRECT_WORKER_URL=https://xiaoyang-direct-media.traderfinn0312.workers.dev
# Mặc định khi không đoán được modelId; bot tự chọn: fast→motion_v26, turbo(117)→motion_v30
XIAOYANG_MODAL_KEY=motion_v26
XIAOYANG_OPTION_KEY=default
XIAOYANG_MOTION_ORIENTATION=video

# Poll giống Aidancing: chỉ poll sau N giây từ submittedAt (300 = 5 phút)
BOT_MIN_RENDER_SEC=300
BOT_POLL_ACTIVE_SEC=90
BOT_POLL_IDLE_SEC=300

# Tùy chọn
XIAOYANG_NO_PROXY=1
XIAOYANG_API_RETRIES=5
XIAOYANG_API_RETRY_SEC=8
