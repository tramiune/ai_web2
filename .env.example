# Fallback 1 nick (nếu không dùng XIAOYANG_ACCOUNTS)
XIAOYANG_EMAIL=you@gmail.com
XIAOYANG_PASSWORD=your_password_here
XIAOYANG_ENHANCE_4K=1
# Batch kênh TikTok (batch_channel.py) — thay đồ full bộ qua VAE /api/wardrobe + render weavy-kling 20s
# wardrobeReplace mặc định full (áo + quần/váy); có thể ghi upper/lower trên batchChannelConfig

